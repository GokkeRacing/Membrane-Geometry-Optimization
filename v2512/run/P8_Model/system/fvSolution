FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
{
    solver          PCG; //PCG
    preconditioner  DIC;
    tolerance       1e-8;
    relTol          1e-4;
    maxIter         20;
}

    U
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          1e-8;
        maxIter         1000;
    }

    
    C_S
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          1e-8;
    }

    C_CO2
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          1e-8;
    }

}


// --------------------------------------------------------------------------
// SIMPLE settings — match the first (working) file exactly
// --------------------------------------------------------------------------

SIMPLE
{
    nNonOrthogonalCorrectors 1;
    nCorrectors         2;
    consistent          yes;
    momentumPredictor   yes;
/*
    residualControl
    {
        p               1e-8; //1e-6
        U               1e-8;
        C_S             1e-12;
        C_CO2           1e-12;
    }
*/
}

// --------------------------------------------------------------------------
// Relaxation factors — identical style to the working configuration
// --------------------------------------------------------------------------

relaxationFactors
{
    fields
    {
        p               0.5;
    }

    equations
    {
        U               0.8;
        C_S             0.8;
        C_CO2           0.8;
    }
}

