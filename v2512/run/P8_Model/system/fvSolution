FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
{
    solver          PCG; //PCG
    preconditioner  DIC;
    tolerance       1e-6;
    relTol          1e-3;
    maxIter         50;
}

pFinal
{
    solver          PCG;
    preconditioner  DIC;
    tolerance       1e-3;
    relTol          0;
}


    U
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-9;
        relTol          1e-4;
        maxIter         1000;
    }

    
    "(C_S|C_CO2)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          1e-8;
    }

}


// --------------------------------------------------------------------------
// SIMPLE settings — match the first (working) file exactly
// --------------------------------------------------------------------------

SIMPLE
{
    nNonOrthogonalCorrectors 1;
    nCorrectors         2;
    consistent          yes;
    momentumPredictor   yes;

    residualControl
    {
        p               0.01; //1e-6
        U               1e-6;
        C_S             1e-12;
        C_CO2           1e-12;
    }
}

// --------------------------------------------------------------------------
// Relaxation factors — identical style to the working configuration
// --------------------------------------------------------------------------

relaxationFactors
{
    fields
    {
        p               0.5;
    }

    equations
    {
        U               0.9;
        C_S             0.9;
        C_CO2           0.9;
    }
}

